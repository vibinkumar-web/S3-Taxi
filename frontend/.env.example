# Backend API URL (used by the frontend for API calls)
# For local development: keep as /backend/api (proxied by Vite)
# For production: set to your full backend URL
VITE_API_URL=/backend/api

# Backend server URL for Vite dev proxy
# Change this if your PHP backend runs on a different port or host
VITE_BACKEND_URL=http://localhost:8080
